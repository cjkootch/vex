# Vex local development environment template.
# Copy to `.env` and fill in provider credentials before running.

NODE_ENV=development
LOG_LEVEL=debug
PORT=3000

# Neon Postgres — the pooled URL is used for all app queries, the direct URL
# is used only by the migration runner.
APPLICATION_DATABASE_URL=postgres://user:pass@ep-xxx-pooler.neon.tech/vex?sslmode=require
MIGRATION_DATABASE_URL=postgres://user:pass@ep-xxx.neon.tech/vex?sslmode=require

# Local Redis (docker-compose)
REDIS_URL=redis://localhost:6379

# Local S3 (Localstack)
S3_ENDPOINT=http://localhost:4566
S3_REGION=us-east-1
S3_BUCKET=vex-local
S3_ACCESS_KEY_ID=test
S3_SECRET_ACCESS_KEY=test

# LLM
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
ANTHROPIC_REASONING_MODEL=claude-sonnet-4-20250514
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Temporal
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=vex-workers

# Telemetry
OTEL_SERVICE_NAME=vex
OTEL_SERVICE_NAMESPACE=vex
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Optional integrations (leave blank if unused)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
RESEND_API_KEY=
# Resend webhook signing secret (Svix format whsec_...). Required to receive
# Resend webhooks; the verifier rejects requests when this is unset.
RESEND_WEBHOOK_SECRET=

# VTC marketing-site chat webhook HMAC-SHA256 secret. Shared with the
# website repo; used to sign `${timestamp}.${rawBody}` and deliver the hex
# digest in `X-VTC-Signature`. Any random 32+ byte string works.
WEBSITE_CHAT_WEBHOOK_SECRET=

# Auth (NextAuth.js v5). Same NEXTAUTH_SECRET must be set on both apps/web
# (which issues tokens) and apps/api (which verifies them).
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
