{
  "name": "@vex/domain",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./ids": {
      "types": "./dist/ids.d.ts",
      "default": "./dist/ids.js"
    },
    "./enums": {
      "types": "./dist/enums.d.ts",
      "default": "./dist/enums.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "devDependencies": {
    "typescript": "5.5.3",
    "vitest": "1.6.0"
  }
}
