{
  "name": "@vex/integrations",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./anthropic": {
      "types": "./dist/anthropic.d.ts",
      "default": "./dist/anthropic.js"
    },
    "./openai": {
      "types": "./dist/openai.d.ts",
      "default": "./dist/openai.js"
    },
    "./twilio": {
      "types": "./dist/twilio.d.ts",
      "default": "./dist/twilio.js"
    },
    "./resend": {
      "types": "./dist/resend.d.ts",
      "default": "./dist/resend.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && mkdir -p dist/fixtures && cp src/fixtures/*.json dist/fixtures/",
    "typecheck": "tsc -p tsconfig.json && mkdir -p dist/fixtures && cp src/fixtures/*.json dist/fixtures/",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.27.3",
    "@temporalio/client": "1.11.1",
    "openai": "4.56.0",
    "resend": "3.5.0",
    "twilio": "5.2.2",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@vex/db": "workspace:*",
    "@vex/domain": "workspace:*",
    "@vex/telemetry": "workspace:*",
    "typescript": "5.5.3",
    "vitest": "1.6.0"
  }
}
