{
  "title": "Vex — Approval pipeline",
  "uid": "vex-approval-pipeline",
  "schemaVersion": 38,
  "version": 1,
  "tags": ["vex", "approvals"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-7d", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "tenant_id",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(vex_approval_pending, tenant_id)",
        "current": { "text": "All", "value": "$__all" },
        "includeAll": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Pending approvals (current)",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(vex_approval_pending{tenant_id=~\"$tenant_id\"})"
        }
      ]
    },
    {
      "id": 2,
      "title": "Pending over time",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 6, "y": 0, "w": 18, "h": 8 },
      "targets": [
        {
          "expr": "sum by (tenant_id) (vex_approval_pending{tenant_id=~\"$tenant_id\"})",
          "legendFormat": "{{tenant_id}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Decision breakdown (24h)",
      "type": "piechart",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (decision) (increase(vex_approval_decided_total{tenant_id=~\"$tenant_id\"}[24h]))",
          "legendFormat": "{{decision}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Time-to-decision (p50/p95)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(vex_approval_time_to_decision_ms_bucket{tenant_id=~\"$tenant_id\"}[1h])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(vex_approval_time_to_decision_ms_bucket{tenant_id=~\"$tenant_id\"}[1h])))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    }
  ]
}
