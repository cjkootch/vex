{
  "title": "Vex — Webhook health",
  "uid": "vex-webhook-health",
  "schemaVersion": 38,
  "version": 1,
  "tags": ["vex", "webhooks"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Webhook RPS by provider + status",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "sum by (provider, status) (rate(vex_webhook_received_total[1m]))",
          "legendFormat": "{{provider}} / {{status}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "DLQ depth",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 4 },
      "targets": [{ "expr": "max(vex_dlq_depth)" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Invalid signature rate",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 6, "y": 8, "w": 18, "h": 4 },
      "targets": [
        {
          "expr": "sum by (provider) (rate(vex_webhook_received_total{status=\"invalid_signature\"}[5m]))",
          "legendFormat": "{{provider}}"
        }
      ]
    }
  ]
}
