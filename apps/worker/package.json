{
  "name": "@vex/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "replay": "tsx src/cli/replay.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@temporalio/activity": "1.11.1",
    "@temporalio/client": "1.11.1",
    "@temporalio/worker": "1.11.1",
    "@temporalio/workflow": "1.11.1",
    "@vex/agents": "workspace:*",
    "@vex/config": "workspace:*",
    "@vex/db": "workspace:*",
    "@vex/domain": "workspace:*",
    "@vex/integrations": "workspace:*",
    "@vex/telemetry": "workspace:*",
    "bullmq": "5.12.0",
    "drizzle-orm": "0.32.0",
    "ioredis": "5.4.1"
  },
  "devDependencies": {
    "tsx": "4.16.2",
    "typescript": "5.5.3",
    "vitest": "1.6.0"
  }
}
