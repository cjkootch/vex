{
  "name": "@vex/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@nestjs/common": "10.3.10",
    "@nestjs/core": "10.3.10",
    "@nestjs/platform-fastify": "10.3.10",
    "@vex/agents": "workspace:*",
    "@vex/config": "workspace:*",
    "@vex/db": "workspace:*",
    "@vex/domain": "workspace:*",
    "@vex/integrations": "workspace:*",
    "@vex/telemetry": "workspace:*",
    "@vex/ui": "workspace:*",
    "@auth/core": "0.34.2",
    "zod": "3.23.8",
    "bullmq": "5.12.0",
    "fastify": "4.28.1",
    "ioredis": "5.4.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "twilio": "5.2.2"
  },
  "devDependencies": {
    "tsx": "4.16.2",
    "typescript": "5.5.3",
    "vitest": "1.6.0"
  }
}
